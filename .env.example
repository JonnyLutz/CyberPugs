# CyberPugs Bedrock API
#
# The dev server runs:
# - Vite on http://localhost:5173 (or next free port)
# - Express API on http://127.0.0.1:8787
#
# The API uses the standard AWS credential chain (env vars, profiles/SSO, etc).

# Bedrock region (must match where you enabled model access)
AWS_REGION=us-east-1

# Optional: comma-separated model IDs you enabled in Bedrock
BEDROCK_MODEL_ALLOWLIST=us.amazon.nova-lite-v1:0,us.amazon.nova-micro-v1:0

# Optional: server-side max output tokens for Converse (default 700)
CONVERSE_MAX_OUTPUT_TOKENS=700

# Optional: hard cap for max tokens (default 8192)
MAX_OUTPUT_TOKENS_CAP=8192

# Optional: API port (default 8787)
PORT=8787

# --- Production: browser on another origin (e.g. static site + API host) ---
# Build the SPA with the API origin so fetches hit your deployed Express server:
#   VITE_BEDROCK_API_BASE=https://your-api.example.com
# On the API server, allow that site origin:
#   CORS_ORIGIN=https://your-static-site.example.com
